generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameReview {
  reviewId Int      @id @default(autoincrement())
  gameId   String
  userId   String
  comment  String
  ratings  Int
  date     DateTime @default(now())
  resources GameReviewResource[]

  @@index([gameId])
  @@index([userId])
}

model GameReviewResource {
  id           Int      @id @default(autoincrement())
  gameReviewId Int
  title        String
  type         String   @default("other")
  url          String
  createdAt    DateTime @default(now())

  gameReview GameReview @relation(fields: [gameReviewId], references: [reviewId], onDelete: Cascade)

  @@index([gameReviewId])
  @@unique([gameReviewId, url])
}

enum GameStatus {
  backlog
  playing
  completed
}

model UserGame {
  id        Int        @id @default(autoincrement())
  title     String
  platform  String
  status    GameStatus @default(backlog)
}
